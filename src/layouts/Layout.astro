---
interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'PËRLA - Science-Led Nutrition. Beautifully Simple.',
  description = 'Aesthetic nutrition protocols, meal systems, and structured programs designed by a bioengineering student. Science meets the art of eating well.',
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <title>{title}</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <!-- Preconnect for fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  </head>
  <body class="bg-brand-warm-white text-brand-dark font-sans">
    <slot />

    <!-- Scroll-triggered fade-up observer -->
    <script>
      const observer = new IntersectionObserver(
        (entries) => {
          entries.forEach((entry) => {
            if (entry.isIntersecting) {
              entry.target.classList.add('is-visible');
            }
          });
        },
        { threshold: 0.12 }
      );

      document.querySelectorAll('.fade-up').forEach((el) => observer.observe(el));
    </script>
  </body>
</html>
