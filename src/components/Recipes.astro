---
const recipes = [
  { title: 'Example 1', tags: 'High Protein · Anti-Inflammatory', color: 'green', time: '15 min' },
  { title: 'Example 2', tags: 'Gluten-Free · Macro-Balanced', color: 'orange', time: '25 min' },
  { title: 'Example 3', tags: 'Slow Carb · Pre-Workout', color: 'warm', time: '10 min' },
  { title: 'Example 4', tags: 'Vegan · High Fiber', color: 'sage', time: '20 min' },
  { title: 'Example 5', tags: 'High Protein · Meal Prep', color: 'cream', time: '20 min' },
  { title: 'Example 6', tags: 'Low Carb · Gut-Friendly', color: 'orange', time: '12 min' },
];
---

<section id="recipes" class="bg-brand-cream py-[100px]">
  <div class="max-w-[1200px] mx-auto px-7">
    <!-- Header -->
    <div class="text-center">
      <div class="fade-up">
        <span class="section-label">Featured Recipes</span>
      </div>
      <div class="fade-up delay-1">
        <h2 class="section-heading text-[36px] sm:text-[44px] mt-4">
          Built for your body.<br />Designed for your eyes.
        </h2>
      </div>
      <div class="fade-up delay-2">
        <p class="body-text mt-5 max-w-[480px] mx-auto">
          Each recipe is macro-calculated, prep-friendly, and crafted to look as good as it
          makes you feel.
        </p>
      </div>
    </div>

    <!-- Recipe grid -->
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6 mt-14">
      {recipes.map((r, i) => (
        <div class={`fade-up delay-${Math.min(i + 1, 5)}`}>
          <div class="bg-brand-warm-white rounded-lg overflow-hidden cursor-pointer card-lift">
            <!-- Replace with actual food photo -->
            <div class={`placeholder-${r.color} aspect-[4/3] flex items-center justify-center relative overflow-hidden`}>
              <div class="absolute inset-0 bg-brand-dark/25"></div>
              <span class="relative z-10 font-serif text-[14px] tracking-[2px] uppercase text-white">Photo</span>
            </div>

            <div class="p-5 pb-6">
              <div class="font-sans text-[10px] tracking-[2px] uppercase text-brand-sage font-semibold">
                {r.tags}
              </div>
              <div class="font-serif text-[22px] text-brand-dark mt-2 leading-tight">
                {r.title}
              </div>
              <div class="font-sans text-[12px] text-brand-taupe mt-3 flex items-center gap-1.5">
                <span class="text-[14px]">⏱</span> {r.time}
              </div>
            </div>
          </div>
        </div>
      ))}
    </div>

    <div class="fade-up delay-4 text-center mt-12">
      <a href="/recipes" class="pill pill-outline">View All Recipes →</a>
    </div>
  </div>
</section>
