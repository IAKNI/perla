---
const articles = [
  { title: 'Article Example 1', cat: 'Nutrition Science', color: 'sage' },
  { title: 'Article Example 2', cat: 'Research', color: 'green' },
  { title: 'Article Example 3', cat: 'Practical Guide', color: 'warm' },
  { title: 'Article Example 4', cat: 'Opinion', color: 'cream' },
];
---

<section id="learn" class="bg-brand-warm-white py-[100px]">
  <div class="max-w-[1200px] mx-auto px-7">
    <div class="fade-up">
      <span class="section-label">Knowledge Library</span>
    </div>
    <div class="fade-up delay-1">
      <h2 class="section-heading text-[36px] sm:text-[44px] mt-4 max-w-[500px]">
        Learn the why behind every bite.
      </h2>
    </div>

    <div class="grid grid-cols-2 lg:grid-cols-4 gap-6 mt-12">
      {articles.map((a, i) => (
        <div class={`fade-up delay-${Math.min(i + 1, 5)} cursor-pointer group`}>
          <div class={`placeholder-${a.color} rounded-md aspect-[3/2]`}></div>
          <div class="font-sans text-[10px] tracking-[2px] uppercase text-brand-sage font-semibold mt-4">
            {a.cat}
          </div>
          <div class="font-serif text-[20px] text-brand-dark mt-2 leading-snug group-hover:text-brand-sage transition-colors">
            {a.title}
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
