---
const items = [
  'High Protein',
  'Anti-Inflammatory',
  'Body Composition',
  'Gut Health',
  'Macro Balanced',
  'Clean Eating',
  'Science-Led',
  'Meal Prep',
];
// Triple for seamless loop
const tripled = [...items, ...items, ...items];
---

<div class="bg-brand-dark py-[18px] overflow-hidden whitespace-nowrap">
  <div class="inline-flex animate-marquee">
    {tripled.map((text) => (
      <span class="font-serif text-[14px] tracking-[4px] uppercase text-white/60 mr-14">
        {text} <span class="text-brand-sage mx-2">✦</span>
      </span>
    ))}
  </div>
</div>
