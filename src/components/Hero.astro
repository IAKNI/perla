---
// Hero section - main landing area
---

<section class="min-h-screen bg-brand-cream flex items-center relative overflow-hidden">
  <!-- Dot grid texture -->
  <div class="absolute inset-0 dot-grid"></div>

  <div class="max-w-[1200px] mx-auto px-7 pt-[140px] pb-[100px] w-full relative z-10">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-center">
      <!-- Left content -->
      <div>
        <div class="fade-up">
          <span class="section-label">Bioengineering × Nutrition</span>
        </div>

        <div class="fade-up delay-1">
          <h1 class="section-heading text-[42px] sm:text-[56px] mt-5 max-w-[520px]">
            Eat with intention.<br />
            <span class="text-brand-sage">Live with clarity.</span>
          </h1>
        </div>

        <div class="fade-up delay-2">
          <p class="body-text mt-7 max-w-[440px]">
            Science-backed nutrition protocols, aesthetic meal systems, and structured programs
            designed by a bioengineering student who believes discipline and beauty coexist on
            every plate.
          </p>
        </div>

        <div class="fade-up delay-3 mt-10 flex gap-4 flex-wrap">
          <a href="#programs" class="pill pill-dark">Explore Programs</a>
          <a href="#newsletter" class="pill pill-outline">Free 7-Day Guide</a>
        </div>

        <!-- Trust metrics -->
        <div class="fade-up delay-4 mt-14 flex gap-10">
          <div>
            <div class="font-serif text-[28px] font-medium text-brand-dark">2.4K+</div>
            <div class="font-sans text-[11px] tracking-[1.5px] uppercase text-brand-taupe mt-1">Followers</div>
          </div>
          <div>
            <div class="font-serif text-[28px] font-medium text-brand-dark">180+</div>
            <div class="font-sans text-[11px] tracking-[1.5px] uppercase text-brand-taupe mt-1">Recipes</div>
          </div>
          <div>
            <div class="font-serif text-[28px] font-medium text-brand-dark">96%</div>
            <div class="font-sans text-[11px] tracking-[1.5px] uppercase text-brand-taupe mt-1">Satisfaction</div>
          </div>
        </div>
      </div>

      <!-- Right - hero image composition -->
      <div class="fade-up delay-2 relative hidden lg:block">
        <!-- Decorative circle -->
        <div class="absolute -top-5 -right-5 w-[180px] h-[180px] rounded-full bg-brand-light-sage opacity-40"></div>

        <div class="grid grid-cols-2 gap-3 relative">
          <div class="row-span-2">
            <!-- Replace src with actual hero image -->
            <div class="placeholder-sage rounded-md aspect-[3/5] flex items-center justify-center relative overflow-hidden">
              <div class="absolute inset-0 bg-brand-dark/25"></div>
              <span class="relative z-10 font-serif text-[14px] tracking-[2px] uppercase text-white">Hero Image</span>
            </div>
          </div>
          <div class="placeholder-warm rounded-md aspect-square flex items-center justify-center relative overflow-hidden">
            <div class="absolute inset-0 bg-brand-dark/25"></div>
            <span class="relative z-10 font-serif text-[14px] tracking-[2px] uppercase text-white">Meal</span>
          </div>
          <div class="placeholder-green rounded-md aspect-square flex items-center justify-center relative overflow-hidden">
            <div class="absolute inset-0 bg-brand-dark/25"></div>
            <span class="relative z-10 font-serif text-[14px] tracking-[2px] uppercase text-white">Recipe</span>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
