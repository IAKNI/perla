---
const items = [
  { name: 'Shop Example 1', price: '$48', color: 'cream' },
  { name: 'Shop Example 2', price: '$32', color: 'sage' },
  { name: 'Shop Example 3', price: '$56', color: 'warm' },
];
---

<section class="bg-brand-cream py-[100px]">
  <div class="max-w-[1200px] mx-auto px-7">
    <div class="grid grid-cols-1 lg:grid-cols-3 gap-16 items-center">
      <!-- Left copy -->
      <div>
        <div class="fade-up">
          <span class="section-label">The Shop</span>
        </div>
        <div class="fade-up delay-1">
          <h2 class="section-heading text-[36px] sm:text-[40px] mt-4">
            Tools for a<br />nourished life.
          </h2>
        </div>
        <div class="fade-up delay-2">
          <p class="body-text mt-5">
            Curated kitchen essentials and branded accessories designed to make beautiful,
            healthy eating effortless.
          </p>
        </div>
        <div class="fade-up delay-3 mt-8">
          <a href="/shop" class="pill pill-dark">Visit Shop →</a>
        </div>
      </div>

      <!-- Product grid -->
      <div class="lg:col-span-2 grid grid-cols-2 sm:grid-cols-3 gap-5">
        {items.map((item, i) => (
          <div class={`fade-up delay-${i + 1} cursor-pointer group`}>
            <div class={`placeholder-${item.color} rounded-md aspect-square flex items-center justify-center`}>
              <span class="font-serif text-[14px] tracking-[2px] uppercase text-brand-dark/40">Product</span>
            </div>
            <div class="font-sans text-[13px] text-brand-dark mt-3.5 font-medium group-hover:text-brand-sage transition-colors">
              {item.name}
            </div>
            <div class="font-serif text-[18px] text-brand-taupe mt-1">{item.price}</div>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>
