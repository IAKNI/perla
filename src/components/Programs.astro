---
const programs = [
  {
    name: 'Program Example 1',
    duration: '8 weeks',
    desc: 'Description for the premium program. Detail the structure, deliverables, check-in cadence, and expected outcomes.',
    features: ['Custom meal framework', 'Weekly grocery lists', 'Bi-weekly video check-in', 'Private community access'],
    price: '$249',
    accent: 'bg-brand-sage',
    button: 'pill-sage',
  },
  {
    name: 'Program Example 2',
    duration: '4 weeks',
    desc: 'Description for the starter program. Explain who it\'s for, what they\'ll learn, and how it builds lasting habits.',
    features: ['Daily meal structure', 'Macro education modules', 'Prep day workflows', 'Email support'],
    price: '$129',
    accent: 'bg-brand-accent',
    button: 'pill-dark',
  },
];
---

<section id="programs" class="bg-brand-cream py-[100px] pb-[120px]">
  <div class="max-w-[1200px] mx-auto px-7">
    <div class="text-center">
      <div class="fade-up">
        <span class="section-label">Programs & Services</span>
      </div>
      <div class="fade-up delay-1">
        <h2 class="section-heading text-[36px] sm:text-[44px] mt-4">
          Guided transformation.<br />Real accountability.
        </h2>
      </div>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-8 mt-14 max-w-[960px] mx-auto">
      {programs.map((p, i) => (
        <div class={`fade-up delay-${i + 1}`}>
          <div class="bg-brand-warm-white rounded-xl p-10 sm:p-12 border border-brand-border relative overflow-hidden h-full flex flex-col">
            <!-- Top accent bar -->
            <div class={`absolute top-0 left-0 right-0 h-1 ${p.accent}`}></div>

            <div class="flex justify-between items-start">
              <div>
                <div class="font-sans text-[11px] tracking-[2px] uppercase text-brand-taupe">{p.duration}</div>
                <h3 class="font-serif text-[32px] text-brand-dark mt-2 leading-tight">{p.name}</h3>
              </div>
              <span class="font-serif text-[36px] font-medium text-brand-dark">{p.price}</span>
            </div>

            <p class="body-text mt-5">{p.desc}</p>

            <!-- Feature list -->
            <div class="mt-7 flex-1">
              {p.features.map((f) => (
                <div class="font-sans text-[13px] text-brand-dark py-[10px] border-b border-brand-border flex items-center gap-2.5">
                  <span class="text-brand-sage text-[14px]">✓</span>
                  {f}
                </div>
              ))}
            </div>

            <div class="mt-8">
              <a href="#" class={`pill pill-full ${p.button}`}>Learn More</a>
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
